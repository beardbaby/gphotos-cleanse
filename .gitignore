# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# python helper environment (created on each user's machine by start-helper)
code/.venv/

# helper download bundles code/credentials.json — NEVER commit it to a public
# repo. Build it with `bash pack-helper.sh` and host it privately (GitHub Release
# or a private repo). See DEPLOY.md.
public/duplicate-finder-helper.zip

# testing
/coverage

# production
/build

# extension signing key — KEEP PRIVATE, never commit (used only to pack/publish
# the extension later; the public half lives in the extension's manifest "key")
extension-signing-key.pem

# Google auth — NEVER commit. token.json is personal (per user); credentials.json
# is your OAuth client (share it with friends privately, not in a public repo).
code/token.json
code/credentials.json
code/__pycache__/

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
