# ---- Frontend (Create React App, build-time) ----
# Base URL of the hosted backend. Leave unset for local dev (defaults to
# http://localhost:8000). Set this before `npm run build` for production.
# REACT_APP_API_BASE=https://api.yourdomain.com

# ---- Backend (FastAPI, runtime env vars — NOT read from this file automatically) ----
# Comma-separated list of allowed frontend origins for CORS.
# Defaults to http://localhost:3000.
# FRONTEND_ORIGINS=https://yourdomain.com

# ---- Backend, needed for the multi-user OAuth rework (not yet implemented) ----
# Path to your Google Cloud "Web application" OAuth client JSON.
# GOOGLE_WEB_CLIENT_SECRET=./client_secret_web.json
# Full redirect URI registered in that OAuth client.
# OAUTH_REDIRECT_URI=https://api.yourdomain.com/auth/callback
# Random secret used to sign session cookies.
# SESSION_SECRET=change-me-to-a-long-random-string
